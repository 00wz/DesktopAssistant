<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DesktopAssistant.UI.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml"/>
        <!-- All icons are forcibly rendered using the Segoe UI Symbol font (monochrome)
             to prevent accidental use of Segoe UI Emoji (color). -->
        <Style Selector="TextBlock.icon">
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
        </Style>
    </Application.Styles>
</Application>