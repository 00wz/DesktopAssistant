<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DesktopAssistant.UI.App"
             xmlns:local="using:DesktopAssistant.UI"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml"/>
        <!-- Все иконки принудительно рендерятся шрифтом Segoe UI Symbol (монохромный),
             чтобы исключить случайное использование Segoe UI Emoji (цветной). -->
        <Style Selector="TextBlock.icon">
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
        </Style>
    </Application.Styles>
</Application>