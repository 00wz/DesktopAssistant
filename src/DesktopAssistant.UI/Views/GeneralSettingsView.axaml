<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:loc="using:DesktopAssistant.UI.Localization"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="300"
             x:Class="DesktopAssistant.UI.Views.GeneralSettingsView"
             x:DataType="vm:GeneralSettingsViewModel">

    <StackPanel Spacing="20">

        <!-- Header -->
        <TextBlock Text="{DynamicResource General.Title}"
                   FontSize="18"
                   FontWeight="SemiBold"/>

        <!-- Interface language -->
        <StackPanel Spacing="8">
            <TextBlock Text="{DynamicResource General.Language.Label}"
                       FontSize="13"
                       FontWeight="SemiBold"/>

            <ComboBox ItemsSource="{Binding AvailableLanguages}"
                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                      MinWidth="200"
                      HorizontalAlignment="Left">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="loc:LanguageOption">
                        <TextBlock Text="{Binding NativeName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="{DynamicResource General.Language.Hint}"
                       FontSize="12"
                       Foreground="#888"
                       TextWrapping="Wrap"/>
        </StackPanel>

    </StackPanel>
</UserControl>
