<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:views="using:DesktopAssistant.UI.Views"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="DesktopAssistant.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

   <Border Background="White">
       <Grid RowDefinitions="Auto,*">

           <!-- Header -->
           <Border Grid.Row="0"
                   Background="#F0F0F0"
                   Padding="20,12"
                   BorderBrush="#E0E0E0"
                   BorderThickness="0,0,0,1">
               <TextBlock Text="{DynamicResource Settings.Title}"
                          FontSize="20"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"/>
           </Border>

           <!-- Two-column layout -->
           <Grid Grid.Row="1" ColumnDefinitions="200,*">

               <!-- Left navigation -->
               <Border Grid.Column="0"
                       Background="#F8F8F8"
                       BorderBrush="#E0E0E0"
                       BorderThickness="0,0,1,0"
                       Padding="0,16,0,0">
                   <StackPanel>
                       <TextBlock Text="{DynamicResource Settings.Nav.Group.Main}"
                                  FontSize="10"
                                  Foreground="#999"
                                  Margin="16,0,0,8"
                                  FontWeight="SemiBold"
                                  LetterSpacing="1"/>

                       <!-- General — navigation item -->
                       <Panel Margin="8,0,8,2">
                           <Border Background="#E8F0FE"
                                   CornerRadius="4"
                                   IsVisible="{Binding IsGeneralActive}"/>
                           <Button Command="{Binding ShowGeneralCommand}"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   Padding="12,8">
                               <TextBlock Text="{DynamicResource Settings.Nav.General}"
                                          FontSize="13"/>
                           </Button>
                       </Panel>

                       <!-- Assistant profiles — navigation item -->
                       <Panel Margin="8,0,8,2">
                           <Border Background="#E8F0FE"
                                   CornerRadius="4"
                                   IsVisible="{Binding IsProfilesActive}"/>
                           <Button Command="{Binding ShowProfilesCommand}"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   Padding="12,8">
                               <TextBlock Text="{DynamicResource Settings.Nav.Profiles}"
                                          FontSize="13"/>
                           </Button>
                       </Panel>

                       <!-- Tool auto-approval — navigation item -->
                       <Panel Margin="8,0,8,2">
                           <Border Background="#E8F0FE"
                                   CornerRadius="4"
                                   IsVisible="{Binding IsToolApprovalActive}"/>
                           <Button Command="{Binding ShowToolApprovalCommand}"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   Padding="12,8">
                               <TextBlock Text="{DynamicResource Settings.Nav.ToolApproval}"
                                          FontSize="13"/>
                           </Button>
                       </Panel>

                   </StackPanel>
               </Border>

               <!-- Right content area.
                    Padding is moved to content Margin: Avalonia does not account for ScrollViewer.Padding
                    when computing Extent, causing the bottom N pixels of content to become unreachable.
                    HorizontalScrollBarVisibility=Disabled: prevents a horizontal scrollbar whose
                    appearance/disappearance would discretely change content width. -->
               <ScrollViewer Grid.Column="1"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">
                   <Panel Margin="24,20,24,20">
                       <!-- General settings section -->
                       <Panel IsVisible="{Binding IsGeneralActive}">
                           <views:GeneralSettingsView DataContext="{Binding GeneralSettings}"/>
                       </Panel>
                       <!-- Profiles section -->
                       <Panel IsVisible="{Binding IsProfilesActive}">
                           <views:ProfilesSettingsView DataContext="{Binding ProfilesSettings}"/>
                       </Panel>
                       <!-- Tool auto-approval section -->
                       <Panel IsVisible="{Binding IsToolApprovalActive}">
                           <views:ToolApprovalSettingsView DataContext="{Binding ToolApprovalSettings}"/>
                       </Panel>
                   </Panel>
               </ScrollViewer>

           </Grid>
       </Grid>
   </Border>
</UserControl>
