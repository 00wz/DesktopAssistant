<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="600"
             x:Class="DesktopAssistant.UI.Views.ConversationSidebarView"
             x:DataType="vm:SidebarViewModel">

   <Grid RowDefinitions="Auto,*,Auto">

       <!-- "New Chat" button (top) -->
       <Border Grid.Row="0" BorderBrush="{DynamicResource ChatHeaderBorderBrush}" BorderThickness="0,0,0,1">
           <Button Classes="sideBtn"
                   Command="{Binding CreateNewChatCommand}"
                   ToolTip.Tip="{DynamicResource Sidebar.NewChat.Tooltip}">
               <StackPanel Orientation="Horizontal" Spacing="10">
                   <TextBlock Classes="icon" Text="+" FontSize="18" VerticalAlignment="Center"
                              Foreground="{DynamicResource SidebarFg}"/>
                   <TextBlock Text="{DynamicResource Sidebar.NewChat}" FontSize="13" VerticalAlignment="Center"/>
               </StackPanel>
           </Button>
       </Border>

       <!-- Conversation list (flat, with manual indentation) -->
       <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
           <StackPanel>
               <TextBlock Text="{DynamicResource Sidebar.NoConversations}"
                          Foreground="{DynamicResource SidebarSecondaryFg}"
                          Margin="15,20"
                          IsVisible="{Binding !FlatConversations.Count}"/>

               <!--
                   Each row is a Panel with two sibling buttons (overlay pattern).
                   The full-width convItem button is the base layer — handles OpenConversationCommand
                   anywhere on the row. The convExpander button is overlaid on top, left-aligned,
                   and only visible when HasChildren is true. When not visible it is non-hit-testable,
                   so clicks in that area fall through to the base button — no dead zones.
               -->
               <ItemsControl ItemsSource="{Binding FlatConversations}">
                   <ItemsControl.ItemTemplate>
                       <DataTemplate DataType="vm:ConversationListItemViewModel">

                           <Panel Background="Transparent">

                               <!-- ── Background layers (full width, non-interactive) ── -->
                               <Border Background="{DynamicResource SidebarItemActiveBg}"
                                       IsVisible="{Binding IsActive}"
                                       IsHitTestVisible="False"/>
                               <Border Background="{DynamicResource SidebarItemSelectedBg}"
                                       IsVisible="{Binding IsSelected}"
                                       IsHitTestVisible="False"/>
                               <Border Background="{DynamicResource SidebarItemHoverOverlay}"
                                       IsVisible="{Binding $parent[Panel].IsPointerOver}"
                                       IsHitTestVisible="False"/>
                               <!-- Left accent bar: 3 px, visible when selected -->
                               <Border Width="3" HorizontalAlignment="Left"
                                       Background="{DynamicResource SidebarItemSelectedAccent}"
                                       IsVisible="{Binding IsSelected}"
                                       IsHitTestVisible="False"/>

                               <!-- Base layer: full-width open button -->
                               <Button Classes="convItem"
                                       HorizontalAlignment="Stretch"
                                       Command="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).OpenConversationCommand}"
                                       CommandParameter="{Binding}">
                                   <Grid ColumnDefinitions="Auto,*" Margin="{Binding IndentMargin}">

                                       <!-- 20 px spacer so title aligns past the expander area -->
                                       <Border Grid.Column="0" Width="20"/>

                                       <!-- Title, date, status icon -->
                                       <Grid Grid.Column="1" ColumnDefinitions="*,18" Margin="4,9,12,9">

                                           <StackPanel Grid.Column="0" Spacing="2">
                                               <TextBlock Text="{Binding Title}"
                                                          FontSize="13"
                                                          Foreground="{DynamicResource SidebarFg}"
                                                          TextTrimming="CharacterEllipsis"
                                                          MaxLines="1"/>
                                               <TextBlock Text="{Binding FormattedDate}"
                                                          FontSize="11"
                                                          Foreground="{DynamicResource SidebarSecondaryFg}"/>
                                           </StackPanel>

                                           <!-- Session status icon -->
                                           <Panel Grid.Column="1" VerticalAlignment="Center" Width="18">

                                               <!-- Loading: spinning star -->
                                               <TextBlock Classes="icon loadingSpin"
                                                          Text="✳"
                                                          IsVisible="{Binding IsLoadingIcon}"
                                                          Classes.loadingSpin="{Binding IsLoadingIcon}"
                                                          Foreground="{DynamicResource SidebarIconLoadingFg}"
                                                          FontSize="13"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                               <!-- Paused; ∥ (U+2225) -->
                                               <TextBlock Classes="icon"
                                                          Text="∥"
                                                          IsVisible="{Binding IsPausedIcon}"
                                                          Foreground="{DynamicResource SidebarIconPausedFg}"
                                                          FontSize="11"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                               <!-- Question: awaiting tool-call approval -->
                                               <TextBlock Text="?"
                                                          IsVisible="{Binding IsQuestionIcon}"
                                                          Classes.questionPulse="{Binding IsQuestionIcon}"
                                                          Foreground="{DynamicResource SidebarIconQuestionFg}"
                                                          FontSize="13"
                                                          FontWeight="Bold"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                               <!-- Error; ⚠ in Segoe UI Symbol -->
                                               <TextBlock Classes="icon"
                                                          Text="⚠"
                                                          IsVisible="{Binding IsErrorIcon}"
                                                          Foreground="{DynamicResource SidebarIconErrorFg}"
                                                          FontSize="11"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                           </Panel>
                                       </Grid>
                                   </Grid>
                               </Button>

                               <!-- Overlay: expander button, only when HasChildren -->
                               <Button Classes="convExpander"
                                       Width="20"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Stretch"
                                       Margin="{Binding IndentMargin}"
                                       IsVisible="{Binding HasChildren}"
                                       Command="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).ToggleExpandCommand}"
                                       CommandParameter="{Binding}">
                                   <TextBlock Classes="icon"
                                              Text="{Binding ExpanderGlyph}"
                                              FontSize="18"
                                              Foreground="{DynamicResource SidebarSecondaryFg}"/>
                               </Button>

                           </Panel>
                       </DataTemplate>
                   </ItemsControl.ItemTemplate>
               </ItemsControl>
           </StackPanel>
       </ScrollViewer>

       <!-- "Settings" button (bottom) -->
       <Border Grid.Row="2" BorderBrush="{DynamicResource ChatHeaderBorderBrush}" BorderThickness="0,1,0,0">
           <Button Classes="sideBtn"
                   Command="{Binding OpenSettingsCommand}"
                   ToolTip.Tip="{DynamicResource Sidebar.Settings.Tooltip}">
               <StackPanel Orientation="Horizontal" Spacing="10">
                   <TextBlock Classes="icon" Text="⚙" FontSize="14" VerticalAlignment="Center"
                              Foreground="{DynamicResource SidebarIconFg}"/>
                   <TextBlock Text="{DynamicResource Sidebar.Settings}" FontSize="13" VerticalAlignment="Center"
                              Foreground="{DynamicResource SidebarIconFg}"/>
               </StackPanel>
           </Button>
       </Border>

   </Grid>
</UserControl>
