<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="600"
             x:Class="DesktopAssistant.UI.Views.ConversationSidebarView"
             x:DataType="vm:SidebarViewModel">

    <UserControl.DataTemplates>
        <!--
            Recursive DataTemplate for ConversationListItemViewModel.
            - Uses $parent[UserControl] (= ConversationSidebarView) to reach
              SidebarViewModel commands regardless of nesting level.
            - IndentLeft grows 16px per depth level.
            - Nested ItemsControl uses the same DataTemplate automatically.
        -->
        <DataTemplate DataType="vm:ConversationListItemViewModel">
            <StackPanel>

                <!-- Item row -->
                <Button Classes="convItem"
                        Command="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).OpenConversationCommand}"
                        CommandParameter="{Binding}">
                    <Panel Background="Transparent">
                        <!--
                            Background layers (bottom to top):
                            1. Active session   — dark-grey accent
                            2. Selected         — blue (overlaps active)
                            3. Hover            — semi-transparent white overlay
                        -->
                        <Border Background="{DynamicResource SidebarItemActiveBg}"
                                IsVisible="{Binding IsActive}"/>
                        <Border Background="{DynamicResource SidebarItemSelectedBg}"
                                IsVisible="{Binding IsSelected}"/>
                        <Border Background="{DynamicResource SidebarItemHoverOverlay}"
                                IsVisible="{Binding $parent[Button].IsPointerOver}"/>

                        <!-- Item content; left margin grows 16px per nesting depth level -->
                        <Grid ColumnDefinitions="*,18"
                              Margin="{Binding DepthMargin}">

                            <!-- Title and date -->
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="13"
                                           Foreground="White"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"/>
                                <TextBlock Text="{Binding FormattedDate}"
                                           FontSize="11"
                                           Foreground="{DynamicResource SidebarSecondaryFg}"/>
                            </StackPanel>

                            <!-- Session status icon -->
                            <Panel Grid.Column="1" VerticalAlignment="Center" Width="18">

                                <!-- Loading: spinning star; ✳ (U+2733) is symmetric on all axes -->
                                <TextBlock Classes="icon loadingSpin"
                                           Text="✳"
                                           IsVisible="{Binding IsLoadingIcon}"
                                           Classes.loadingSpin="{Binding IsLoadingIcon}"
                                           Foreground="White"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <!-- Paused; ∥ (U+2225) — double vertical line -->
                                <TextBlock Classes="icon"
                                           Text="∥"
                                           IsVisible="{Binding IsPausedIcon}"
                                           Foreground="White"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <!-- Question: awaiting tool-call approval -->
                                <TextBlock Text="?"
                                           IsVisible="{Binding IsQuestionIcon}"
                                           Classes.questionPulse="{Binding IsQuestionIcon}"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <!-- Error; ⚠ in Segoe UI Symbol — monochrome -->
                                <TextBlock Classes="icon"
                                           Text="⚠"
                                           IsVisible="{Binding IsErrorIcon}"
                                           Foreground="White"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Panel>
                        </Grid>
                    </Panel>
                </Button>

                <!-- Children (rendered recursively via the same DataTemplate) -->
                <ItemsControl ItemsSource="{Binding Children}"
                              IsVisible="{Binding HasChildren}"/>

            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- "New Chat" button (top) -->
        <Button Grid.Row="0"
                Classes="sideBtn"
                Command="{Binding CreateNewChatCommand}"
                ToolTip.Tip="{DynamicResource Sidebar.NewChat.Tooltip}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Classes="icon" Text="+" FontSize="18" VerticalAlignment="Center"
                           Foreground="{DynamicResource SidebarFg}"/>
                <TextBlock Text="{DynamicResource Sidebar.NewChat}" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Conversation list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{DynamicResource Sidebar.NoConversations}"
                           Foreground="{DynamicResource SidebarSecondaryFg}"
                           Margin="15,20"
                           IsVisible="{Binding !Conversations.Count}"/>

                <ItemsControl ItemsSource="{Binding Conversations}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- "Settings" button (bottom) -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource SidebarButtonHoverBg}" BorderThickness="0,1,0,0">
            <Button Classes="sideBtn"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip.Tip="{DynamicResource Sidebar.Settings.Tooltip}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Classes="icon" Text="⚙" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource SidebarIconFg}"/>
                    <TextBlock Text="{DynamicResource Sidebar.Settings}" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource SidebarIconFg}"/>
                </StackPanel>
            </Button>
        </Border>

    </Grid>
</UserControl>
