<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:views="using:DesktopAssistant.UI.Views"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="120"
             x:Class="DesktopAssistant.UI.Views.MessageInputView"
             x:DataType="vm:ChatViewModel">

    <Border Background="#F5F5F5" Padding="10">
        <StackPanel Spacing="6">

            <!-- Error -->
            <Border Background="#FFE0E0"
                    Padding="10"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#CC0000"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Message input -->
            <views:TextInputWithButtonView IsVisible="{Binding ShowInputPanel}"
                                          Text="{Binding InputMessage, Mode=TwoWay}"
                                          Watermark="{DynamicResource MessageInput.Placeholder}"
                                          SendCommand="{Binding SendMessageCommand}"
                                          IsSendEnabled="{Binding !IsLoading}"
                                          InputVerticalContentAlignment="Center"/>

            <!-- Resume button -->
            <Button Content="{DynamicResource MessageInput.Resume}"
                    IsVisible="{Binding ShowResumePanel}"
                    Command="{Binding ResumeCommand}"
                    HorizontalAlignment="Stretch"
                    Height="40"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>

        </StackPanel>
    </Border>
</UserControl>
