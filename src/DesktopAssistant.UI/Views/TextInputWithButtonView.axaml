<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DesktopAssistant.UI.Views.TextInputWithButtonView"
             x:Name="Self">

    <Panel>
        <TextBox Text="{Binding Text, ElementName=Self, Mode=TwoWay}"
                 Watermark="{Binding Watermark, ElementName=Self}"
                 AcceptsReturn="False"
                 TextWrapping="Wrap"
                 MinHeight="{Binding MinInputHeight, ElementName=Self}"
                 MaxHeight="{Binding MaxInputHeight, ElementName=Self}"
                 Padding="8,8,40,8"
                 VerticalContentAlignment="{Binding InputVerticalContentAlignment, ElementName=Self}"
                 KeyDown="TextBox_KeyDown"/>
        <Button Command="{Binding SendCommand, ElementName=Self}"
                IsEnabled="{Binding IsSendEnabled, ElementName=Self}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="4">
            <TextBlock Classes="icon" Text="🡹" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Button>
    </Panel>

</UserControl>
