<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DesktopAssistant.UI.ViewModels"
        xmlns:views="using:DesktopAssistant.UI.Views"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="DesktopAssistant.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Desktop Assistant"
        Width="1000"
        Height="700"
        MinWidth="700"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <!-- Кнопки управления окном (светлый фон) -->
        <Style Selector="Button.winBtn">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            Width="{TemplateBinding Width}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.winBtn:pointerover">
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>
        <Style Selector="Button.winBtn:pressed">
            <Setter Property="Background" Value="#D0D0D0"/>
        </Style>
        <Style Selector="Button.winBtn.close:pointerover">
            <Setter Property="Background" Value="#C42B1C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.winBtn.close:pressed">
            <Setter Property="Background" Value="#A82318"/>
        </Style>
    </Window.Styles>

    <Grid x:Name="RootGrid" RowDefinitions="Auto,*">

        <!-- ── Полноширокая шапка окна ── -->
        <!-- PointerPressed на всём заголовке; кнопки помечают событие как Handled -->
        <Border Grid.Row="0" Background="#F0F0F0" MinHeight="38"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Название приложения у левого края; IsHitTestVisible=False — события проходят к Border -->
                <TextBlock Grid.Column="0"
                           Text="Desktop Assistant"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="15,0,0,0"
                           IsHitTestVisible="False"/>

                <!-- Кнопки управления окном -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="winBtn" Click="MinimizeButton_Click"
                            ToolTip.Tip="{DynamicResource MainWindow.TitleBar.Minimize}">
                        <TextBlock Classes="icon" Text="&#x2014;" FontSize="12"/>
                    </Button>
                    <Button Classes="winBtn" x:Name="MaxRestoreButton"
                            Click="MaximizeButton_Click"
                            ToolTip.Tip="{DynamicResource MainWindow.TitleBar.MaximizeRestore}">
                        <TextBlock Classes="icon" x:Name="MaxRestoreIcon" Text="&#x25A1;" FontSize="12"/>
                    </Button>
                    <Button Classes="winBtn close" Click="CloseButton_Click"
                            ToolTip.Tip="{DynamicResource MainWindow.TitleBar.Close}">
                        <TextBlock Classes="icon" Text="&#x2715;" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Основной контент: сайдбар + рабочая область ── -->
        <Grid Grid.Row="1" ColumnDefinitions="260,*">

            <!-- Боковая панель (всегда открыта) -->
            <Border Grid.Column="0" Background="#2D2D30">
                <views:ConversationSidebarView DataContext="{Binding Sidebar}"/>
            </Border>

            <!-- Рабочая область -->
            <Grid Grid.Column="1">

                <!-- Активный диалог -->
                <Panel IsVisible="{Binding HasActiveChat}">
                    <views:ChatView DataContext="{Binding SelectedChat}"/>
                </Panel>

                <!-- Пустое состояние (нет выбранного диалога) -->
                <Border Background="#FAFAFA"
                        IsVisible="{Binding !HasActiveChat}">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="20"
                                IsVisible="{Binding !IsNewConversationPanelVisible}">
                        <TextBlock Text="{DynamicResource MainWindow.Welcome.Title}"
                                   FontSize="24"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource MainWindow.Welcome.Subtitle}"
                                   FontSize="14"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                        <Button Content="{DynamicResource MainWindow.Welcome.NewChat}"
                                Command="{Binding CreateNewChatCommand}"
                                HorizontalAlignment="Center"
                                Padding="20,10"/>
                    </StackPanel>
                </Border>

                <!-- Inline-панель создания нового диалога (поверх остальных) -->
                <Border IsVisible="{Binding IsNewConversationPanelVisible}"
                        Background="#FAFAFA">
                    <views:NewConversationPanelView DataContext="{Binding NewConversationPanel}"/>
                </Border>

                <!-- Панель настроек (поверх всего) -->
                <Border IsVisible="{Binding IsSettingsVisible}"
                        Background="White">
                    <views:SettingsView DataContext="{Binding SettingsView}"/>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>
