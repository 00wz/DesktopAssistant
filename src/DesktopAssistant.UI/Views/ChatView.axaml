<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:models="using:DesktopAssistant.UI.Models"
             xmlns:views="using:DesktopAssistant.UI.Views"
             xmlns:converters="using:DesktopAssistant.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="DesktopAssistant.UI.Views.ChatView"
             x:DataType="vm:ChatViewModel">

    <UserControl.Resources>
        <!-- Used in the chat header to show/hide token count when > 1 -->
        <converters:IntGreaterThanConverter x:Key="IntGreaterThanConverter" Threshold="1"/>
    </UserControl.Resources>

    <UserControl.DataTemplates>

        <!-- Each DataTemplate is a thin wrapper that wires ChatViewModel commands
             to the dedicated message UserControl via StyledProperties. -->

        <DataTemplate DataType="models:UserChatMessageModel">
            <views:UserMessageView
                SummarizeCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SummarizeMessageCommand}"
                NavigateToPreviousSiblingCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).NavigateToPreviousSiblingCommand}"
                NavigateToNextSiblingCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).NavigateToNextSiblingCommand}"
                StartEditMessageCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).StartEditMessageCommand}"
                SaveEditedMessageCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SaveEditedMessageCommand}"
                CancelEditMessageCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).CancelEditMessageCommand}"/>
        </DataTemplate>

        <DataTemplate DataType="models:AssistantChatMessageModel">
            <views:AssistantMessageView
                SummarizeCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SummarizeMessageCommand}"/>
        </DataTemplate>

        <DataTemplate DataType="models:ToolChatMessageModel">
            <views:ToolCallView
                SummarizeCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SummarizeMessageCommand}"
                ApproveToolCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).ApproveToolCommand}"
                DenyToolCommand="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).DenyToolCommand}"/>
        </DataTemplate>

        <DataTemplate DataType="models:SummarizationChatMessageModel">
            <views:SummarizationMessageView/>
        </DataTemplate>

    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Chat header with settings button -->
        <Border Grid.Row="0"
                Background="{DynamicResource ChatHeaderBg}"
                Padding="10,6"
                BorderBrush="{DynamicResource ChatHeaderBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AssistantProfileName}"
                               FontSize="12"
                               Foreground="{DynamicResource ChatHeaderProfileFg}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding AssistantProfileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           FontSize="11"
                           Foreground="{DynamicResource ChatHeaderTokenFg}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           IsVisible="{Binding LastTotalTokenCount, Converter={StaticResource IntGreaterThanConverter}}">
                    <Run Text=" Σ"/>
                    <Run Text="{Binding LastTotalTokenCount}"/>
                </TextBlock>
                <Button Grid.Column="2"
                        Command="{Binding ToggleSettingsPanelCommand}"
                        ToolTip.Tip="{DynamicResource Chat.Tooltip.ChatSettings}"
                        Background="Transparent"
                        Padding="8,4">
                    <TextBlock Classes="icon" Text="⚙" FontSize="16"/>
                </Button>
            </Grid>
        </Border>

        <!-- Chat settings panel -->
        <Border Grid.Row="1" IsVisible="{Binding IsSettingsPanelVisible}">
            <views:ChatSettingsPanelView DataContext="{Binding Settings}"/>
        </Border>

        <!-- Message list + floating input panel -->
        <Panel Grid.Row="2">
            <ScrollViewer Name="MessagesScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Messages}" Margin="10,10,10,0"/>
                    <!-- Spacer so last message is not hidden behind the input panel -->
                    <Border Height="{Binding #MessageInput.Bounds.Height}"/>
                </StackPanel>
            </ScrollViewer>

            <views:MessageInputView x:Name="MessageInput"
                                    VerticalAlignment="Bottom"/>
        </Panel>

    </Grid>
</UserControl>
