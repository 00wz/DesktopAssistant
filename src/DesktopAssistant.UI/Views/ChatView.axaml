<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:models="using:DesktopAssistant.UI.Models"
             xmlns:views="using:DesktopAssistant.UI.Views"
             xmlns:converters="using:DesktopAssistant.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="DesktopAssistant.UI.Views.ChatView"
             x:DataType="vm:ChatViewModel">

    <UserControl.Resources>
        <converters:BoolToValueConverter x:Key="UserMessageForegroundConverter"
                                         TrueValue="White"
                                         FalseValue="Black"/>
        <converters:BoolToValueConverter x:Key="UserMessageBackgroundConverter"
                                         TrueValue="#007ACC"
                                         FalseValue="#E8E8E8"/>
        <converters:BoolToValueConverter x:Key="UserMessageAlignmentConverter"
                                         TrueValue="Right"
                                         FalseValue="Left"/>
        <converters:IntGreaterThanConverter x:Key="IntGreaterThanConverter" Threshold="1"/>
    </UserControl.Resources>

    <UserControl.DataTemplates>

        <!-- TextChatMessageModel -->
        <DataTemplate DataType="models:TextChatMessageModel">
            <Border Margin="5"
                    Padding="12"
                    CornerRadius="12"
                    MaxWidth="500"
                    Background="{Binding IsUser, Converter={StaticResource UserMessageBackgroundConverter}}"
                    HorizontalAlignment="{Binding IsUser, Converter={StaticResource UserMessageAlignmentConverter}}">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Суммаризировать контекст"
                                  Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SummarizeMessageCommand}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <StackPanel IsVisible="{Binding !IsEditing}">
                        <TextBlock Text="{Binding Content}"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding IsUser, Converter={StaticResource UserMessageForegroundConverter}}"/>
                        <Button Content="✏️"
                                IsVisible="{Binding IsUser}"
                                Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).StartEditMessageCommand}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Right"
                                Margin="0,5,0,0"
                                Padding="5,2"
                                Background="Transparent"
                                ToolTip.Tip="Редактировать"/>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsEditing}">
                        <TextBox Text="{Binding EditedContent, Mode=TwoWay}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Button Content="Сохранить"
                                    Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SaveEditedMessageCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="Отмена"
                                    Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).CancelEditMessageCommand}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,5,0,0"
                                IsVisible="{Binding TotalSiblings, Converter={StaticResource IntGreaterThanConverter}}">
                        <Button Content="◀"
                                Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).NavigateToPreviousSiblingCommand}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding HasPreviousSibling}"
                                Padding="8,2"
                                ToolTip.Tip="Предыдущая версия"/>
                        <TextBlock VerticalAlignment="Center" Margin="10,0"
                                   Foreground="{Binding IsUser, Converter={StaticResource UserMessageForegroundConverter}}">
                            <Run Text="{Binding CurrentSiblingIndex}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TotalSiblings}"/>
                        </TextBlock>
                        <Button Content="▶"
                                Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).NavigateToNextSiblingCommand}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding HasNextSibling}"
                                Padding="8,2"
                                ToolTip.Tip="Следующая версия"/>
                    </StackPanel>

                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsStreaming}"
                                 Height="3"
                                 Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ToolChatMessageModel -->
        <DataTemplate DataType="models:ToolChatMessageModel">
            <Border Background="#F0F4FF"
                    CornerRadius="8"
                    Margin="5,3"
                    Padding="2"
                    MaxWidth="500"
                    HorizontalAlignment="Left">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Суммаризировать контекст"
                                  Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SummarizeMessageCommand}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Expander>
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="🔧" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PluginName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="." VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FunctionName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Status}"
                                       Foreground="Gray"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="4" Spacing="6">
                        <TextBlock Text="{Binding ArgumentsJson}"
                                   FontFamily="Courier New,Monospace"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="#333333"/>
                        <TextBlock Text="{Binding ResultJson}"
                                   IsVisible="{Binding HasResult}"
                                   FontFamily="Courier New,Monospace"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="#226622"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsPending}">
                            <Button Content="Подтвердить"
                                    Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).ApproveToolCommand}"
                                    CommandParameter="{Binding}"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    Padding="10,5"/>
                            <Button Content="Отклонить"
                                    Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).DenyToolCommand}"
                                    CommandParameter="{Binding}"
                                    Background="#F44336"
                                    Foreground="White"
                                    Padding="10,5"/>
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsExecuting}" Height="3"/>
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- SummarizationChatMessageModel -->
        <DataTemplate DataType="models:SummarizationChatMessageModel">
            <Border Background="#FFF9E6"
                    CornerRadius="8"
                    Margin="5,3"
                    Padding="2"
                    MaxWidth="500"
                    HorizontalAlignment="Left">
                <Expander>
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="📋" VerticalAlignment="Center"/>
                            <TextBlock Text="Сводка" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="Gray"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                            <ProgressBar IsIndeterminate="True"
                                         IsVisible="{Binding IsInProgress}"
                                         Width="60"
                                         Height="3"
                                         VerticalAlignment="Center"
                                         Margin="6,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>
                    <TextBlock Text="{Binding SummaryContent}"
                               IsVisible="{Binding !IsInProgress}"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#444444"
                               Margin="4"/>
                </Expander>
            </Border>
        </DataTemplate>

    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Заголовок чата с кнопкой настроек -->
        <Border Grid.Row="0"
                Background="#F5F5F5"
                Padding="10,6"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConversationTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AssistantProfileName}"
                               FontSize="12"
                               Foreground="#666"
                               VerticalAlignment="Center"
                               IsVisible="{Binding AssistantProfileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           FontSize="11"
                           Foreground="#999"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           IsVisible="{Binding LastTotalTokenCount, Converter={StaticResource IntGreaterThanConverter}}">
                    <Run Text=" Σ"/>
                    <Run Text="{Binding LastTotalTokenCount}"/>
                </TextBlock>
                <Button Grid.Column="2"
                        Command="{Binding ToggleSettingsPanelCommand}"
                        ToolTip.Tip="Настройки диалога"
                        Background="Transparent"
                        Padding="8,4">
                    <TextBlock Text="⚙" FontSize="16"/>
                </Button>
            </Grid>
        </Border>

        <!-- Панель настроек диалога -->
        <views:ChatSettingsPanelView Grid.Row="1"
                                     IsVisible="{Binding IsSettingsPanelVisible}"/>

        <!-- Список сообщений -->
        <ScrollViewer Grid.Row="2"
                      Name="MessagesScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Messages}" Margin="10"/>
        </ScrollViewer>

        <!-- Панель ввода -->
        <views:MessageInputView Grid.Row="3"/>


    </Grid>
</UserControl>
