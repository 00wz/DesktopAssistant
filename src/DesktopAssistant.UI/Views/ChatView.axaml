<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:models="using:DesktopAssistant.UI.Models"
             xmlns:converters="using:DesktopAssistant.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="DesktopAssistant.UI.Views.ChatView"
             x:DataType="vm:ChatViewModel">

    <UserControl.Resources>
        <converters:BoolToValueConverter x:Key="UserMessageForegroundConverter"
                                         TrueValue="White"
                                         FalseValue="Black"/>
        <converters:BoolToValueConverter x:Key="UserMessageBackgroundConverter"
                                         TrueValue="#007ACC"
                                         FalseValue="#E8E8E8"/>
        <converters:BoolToValueConverter x:Key="UserMessageAlignmentConverter"
                                         TrueValue="Right"
                                         FalseValue="Left"/>
        <converters:IntGreaterThanConverter x:Key="IntGreaterThanConverter" Threshold="1"/>
    </UserControl.Resources>

    <UserControl.DataTemplates>

        <!-- TextChatMessageModel -->
        <DataTemplate DataType="models:TextChatMessageModel">
            <Border Margin="5"
                    Padding="12"
                    CornerRadius="12"
                    MaxWidth="500"
                    Background="{Binding IsUser, Converter={StaticResource UserMessageBackgroundConverter}}"
                    HorizontalAlignment="{Binding IsUser, Converter={StaticResource UserMessageAlignmentConverter}}">
                <StackPanel>
                    <StackPanel IsVisible="{Binding !IsEditing}">
                        <TextBlock Text="{Binding Content}"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding IsUser, Converter={StaticResource UserMessageForegroundConverter}}"/>
                        <Button Content="✏️"
                                IsVisible="{Binding IsUser}"
                                Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).StartEditMessageCommand}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Right"
                                Margin="0,5,0,0"
                                Padding="5,2"
                                Background="Transparent"
                                ToolTip.Tip="Редактировать"/>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsEditing}">
                        <TextBox Text="{Binding EditedContent, Mode=TwoWay}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Button Content="Сохранить"
                                    Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SaveEditedMessageCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="Отмена"
                                    Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).CancelEditMessageCommand}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,5,0,0"
                                IsVisible="{Binding TotalSiblings, Converter={StaticResource IntGreaterThanConverter}}">
                        <Button Content="◀"
                                Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).NavigateToPreviousSiblingCommand}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding HasPreviousSibling}"
                                Padding="8,2"
                                ToolTip.Tip="Предыдущая версия"/>
                        <TextBlock VerticalAlignment="Center" Margin="10,0"
                                   Foreground="{Binding IsUser, Converter={StaticResource UserMessageForegroundConverter}}">
                            <Run Text="{Binding CurrentSiblingIndex}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TotalSiblings}"/>
                        </TextBlock>
                        <Button Content="▶"
                                Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).NavigateToNextSiblingCommand}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding HasNextSibling}"
                                Padding="8,2"
                                ToolTip.Tip="Следующая версия"/>
                    </StackPanel>

                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsStreaming}"
                                 Height="3"
                                 Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ToolChatMessageModel -->
        <DataTemplate DataType="models:ToolChatMessageModel">
            <Border Background="#F0F4FF"
                    CornerRadius="8"
                    Margin="5,3"
                    Padding="2"
                    MaxWidth="500"
                    HorizontalAlignment="Left">
                <Expander>
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="🔧" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PluginName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="." VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FunctionName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Status}"
                                       Foreground="Gray"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="4" Spacing="6">
                        <TextBlock Text="{Binding ArgumentsJson}"
                                   FontFamily="Courier New,Monospace"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="#333333"/>
                        <TextBlock Text="{Binding ResultJson}"
                                   IsVisible="{Binding IsCompleted}"
                                   FontFamily="Courier New,Monospace"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="#226622"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   IsVisible="{Binding IsFailed}"
                                   TextWrapping="Wrap"
                                   Foreground="#CC2222"
                                   FontSize="11"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsPending}">
                            <Button Content="Подтвердить"
                                    Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).ApproveToolCommand}"
                                    CommandParameter="{Binding}"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    Padding="10,5"/>
                            <Button Content="Отклонить"
                                    Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).DenyToolCommand}"
                                    CommandParameter="{Binding}"
                                    Background="#F44336"
                                    Foreground="White"
                                    Padding="10,5"/>
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsExecuting}" Height="3"/>
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- SummarizationChatMessageModel -->
        <DataTemplate DataType="models:SummarizationChatMessageModel">
            <Border Background="#FFF9E6"
                    CornerRadius="6"
                    Margin="5,3"
                    Padding="10,6"
                    MaxWidth="500"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="📋" VerticalAlignment="Center"/>
                    <TextBlock Text="Сводка" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Status}" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SummaryContent}"
                               IsVisible="{Binding !IsInProgress}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsInProgress}"
                                 Width="80"
                                 Height="3"
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Заголовок чата с кнопкой настроек -->
        <Border Grid.Row="0"
                Background="#F5F5F5"
                Padding="10,6"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConversationTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AssistantProfileName}"
                               FontSize="12"
                               Foreground="#666"
                               VerticalAlignment="Center"
                               IsVisible="{Binding AssistantProfileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding ToggleSettingsPanelCommand}"
                        ToolTip.Tip="Настройки диалога"
                        Background="Transparent"
                        Padding="8,4">
                    <TextBlock Text="⚙" FontSize="16"/>
                </Button>
            </Grid>
        </Border>

        <!-- Панель настроек диалога -->
        <Border Grid.Row="1"
                Background="#F8F8FF"
                Padding="12"
                BorderBrush="#DDEEFF"
                BorderThickness="0,0,0,1"
                IsVisible="{Binding IsSettingsPanelVisible}">
            <StackPanel Spacing="10">
                <TextBlock Text="Настройки диалога"
                           FontSize="14"
                           FontWeight="SemiBold"/>

                <!-- Профиль -->
                <Grid ColumnDefinitions="120,*">
                    <TextBlock Grid.Column="0"
                               Text="Профиль:"
                               FontSize="12"
                               Foreground="#555"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailableProfiles}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ModelId}"
                                               Foreground="#888"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- Кнопка применить профиль -->
                <Button Content="Применить профиль"
                        Command="{Binding ChangeProfileCommand}"
                        CommandParameter="{Binding SelectedProfile}"
                        HorizontalAlignment="Right"
                        Padding="12,6"
                        FontSize="12"/>

                <!-- Системный промпт -->
                <TextBlock Text="Системный промпт:" FontSize="12" Foreground="#555"/>
                <TextBox Text="{Binding SystemPrompt, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80"
                         MaxHeight="160"
                         Watermark="Системный промпт пуст..."/>

                <Button Content="Сохранить промпт"
                        Command="{Binding SaveSystemPromptCommand}"
                        HorizontalAlignment="Right"
                        Padding="12,6"
                        FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Список сообщений -->
        <ScrollViewer Grid.Row="2"
                      Name="MessagesScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Messages}" Margin="10"/>
        </ScrollViewer>

        <!-- Панель ввода -->
        <Border Grid.Row="3"
                Background="#F5F5F5"
                Padding="10">
            <StackPanel Spacing="6">

                <!-- Ошибка -->
                <Border Background="#FFE0E0"
                        Padding="10"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#CC0000"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Auto-approve toggle -->
                <CheckBox Content="Авто-подтверждение tools"
                          IsChecked="{Binding IsAutoApproveTools, Mode=TwoWay}"
                          FontSize="12"/>

                <!-- Ввод сообщения -->
                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding ShowInputPanel}">
                    <TextBox Grid.Column="0"
                             Text="{Binding InputMessage, Mode=TwoWay}"
                             Watermark="Введите сообщение..."
                             AcceptsReturn="False"
                             TextWrapping="Wrap"
                             MinHeight="40"
                             MaxHeight="120"
                             VerticalContentAlignment="Center"
                             Margin="0,0,10,0">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SendMessageCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                    <Button Grid.Column="1"
                            Command="{Binding SendMessageCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            Width="80"
                            Height="40"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">
                        <Panel>
                            <TextBlock Text="Отправить" IsVisible="{Binding !IsLoading}"/>
                            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Width="40" Height="4"/>
                        </Panel>
                    </Button>
                </Grid>

                <!-- Кнопка Resume -->
                <Button IsVisible="{Binding ShowResumePanel}"
                        Command="{Binding ResumeCommand}"
                        HorizontalAlignment="Stretch"
                        Height="40"
                        HorizontalContentAlignment="Center">
                    <Panel>
                        <TextBlock Text="Возобновить" IsVisible="{Binding !IsLoading}"/>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Width="40" Height="4"/>
                    </Panel>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
