<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:models="using:DesktopAssistant.UI.Models"
             mc:Ignorable="d" d:DesignWidth="680" d:DesignHeight="500"
             x:Class="DesktopAssistant.UI.Views.ToolApprovalSettingsView"
             x:DataType="vm:ToolApprovalSettingsViewModel">

    <StackPanel Spacing="16">

        <!-- Заголовок секции -->
        <StackPanel Spacing="4">
            <TextBlock Text="{DynamicResource ToolApproval.Title}"
                       FontSize="16"
                       FontWeight="SemiBold"/>
            <TextBlock Text="{DynamicResource ToolApproval.Description}"
                       FontSize="12"
                       Foreground="#666"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Ошибка -->
        <Border Background="#FFE0E0"
                Padding="12"
                CornerRadius="4"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#CC0000"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Индикатор загрузки -->
        <ProgressBar IsIndeterminate="True"
                     Height="2"
                     IsVisible="{Binding IsLoading}"/>

        <!-- Пустой список -->
        <Border Background="#F8F8F8"
                Padding="24"
                CornerRadius="4"
                IsVisible="{Binding !HasGroups}">
            <TextBlock Text="{DynamicResource ToolApproval.Empty}"
                       HorizontalAlignment="Center"
                       Foreground="#888"
                       FontSize="13"/>
        </Border>

        <!-- Группы плагинов/серверов -->
        <ItemsControl ItemsSource="{Binding Groups}"
                      IsVisible="{Binding HasGroups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:ToolApprovalGroupModel">
                    <Border BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="0,0,0,10"
                            ClipToBounds="True">

                        <StackPanel>
                            <!-- Заголовок группы -->
                            <Border Background="#F0F4FF"
                                    Padding="14,9">
                                <TextBlock Text="{Binding PluginName}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#1A3C6E"/>
                            </Border>

                            <!-- Tools группы -->
                            <ItemsControl ItemsSource="{Binding Tools}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:ToolApprovalItemModel">
                                        <Border BorderBrush="#F0F0F0"
                                                BorderThickness="0,1,0,0"
                                                Padding="14,9"
                                                Background="White">
                                            <Grid ColumnDefinitions="*,Auto">

                                                <!-- Информация о tool -->
                                                <StackPanel Grid.Column="0"
                                                            Spacing="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="13"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11"
                                                               Foreground="#888"
                                                               TextWrapping="Wrap"
                                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                </StackPanel>

                                                <!-- Тоггл auto-approve -->
                                                <CheckBox Grid.Column="1"
                                                          IsChecked="{Binding IsAutoApproved, Mode=TwoWay}"
                                                          VerticalAlignment="Center"
                                                          Margin="16,0,0,0"
                                                          ToolTip.Tip="{DynamicResource ToolApproval.AutoApprove.Tooltip}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</UserControl>
