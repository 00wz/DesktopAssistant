<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:views="using:DesktopAssistant.UI.Views"
             mc:Ignorable="d" d:DesignWidth="580" d:DesignHeight="700"
             x:Class="DesktopAssistant.UI.Views.NewConversationPanelView"
             x:DataType="vm:NewConversationPanelViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border MaxWidth="580"
                HorizontalAlignment="Center"
                Margin="20,30,20,20">
            <StackPanel Spacing="16">
                <TextBlock Text="Новый диалог"
                           FontSize="22"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <!-- Заголовок -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Название диалога" FontSize="13" Foreground="#555"/>
                    <TextBox Text="{Binding ConversationTitle, Mode=TwoWay}"
                             Watermark="Например: Помощник по коду"/>
                </StackPanel>

                <!-- Профиль ассистента -->
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Профиль ассистента"
                                   FontSize="13"
                                   Foreground="#555"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleCreateProfileModeCommand}"
                                FontSize="12"
                                Padding="10,4"
                                Background="Transparent">
                            <Button.Content>
                                <Panel>
                                    <TextBlock Text="Отмена" IsVisible="{Binding IsCreateProfileMode}"/>
                                    <TextBlock Text="+ Новый профиль" IsVisible="{Binding !IsCreateProfileMode}"/>
                                </Panel>
                            </Button.Content>
                        </Button>
                    </Grid>

                    <ComboBox ItemsSource="{Binding AvailableProfiles}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              IsVisible="{Binding !IsCreateProfileMode}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding ModelId}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="#888"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               MaxWidth="200"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Нет доступных профилей. Создайте первый профиль."
                               Foreground="#CC8800"
                               FontSize="12"
                               IsVisible="{Binding !AvailableProfiles.Count}"/>
                </StackPanel>

                <!-- Inline-редактор профиля (вместо встроенной формы) -->
                <Panel IsVisible="{Binding IsCreateProfileMode}">
                    <views:ProfileEditorView DataContext="{Binding InlineProfileEditor}"/>
                </Panel>

                <!-- Системный промпт -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Системный промпт (необязательно)"
                               FontSize="13"
                               Foreground="#555"/>
                    <TextBox Text="{Binding SystemPrompt, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="80"
                             MaxHeight="200"
                             Watermark="Вы — полезный ИИ-ассистент..."/>
                </StackPanel>

                <!-- Ошибка -->
                <Border Background="#FFE0E0"
                        Padding="10"
                        CornerRadius="4"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#CC0000"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10"
                            Margin="0,8,0,0">
                    <Button Content="Отмена"
                            Command="{Binding CancelCommand}"
                            Padding="16,10"/>
                    <Button Content="Создать диалог"
                            Command="{Binding ConfirmCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            Padding="20,10"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
