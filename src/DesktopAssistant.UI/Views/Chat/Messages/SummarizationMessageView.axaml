<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:DesktopAssistant.UI.Models"
             xmlns:views="using:DesktopAssistant.UI.Views"
             mc:Ignorable="d"
             x:Class="DesktopAssistant.UI.Views.SummarizationMessageView"
             x:DataType="models:SummarizationChatMessageModel">

    <Border Background="{DynamicResource SummarizationBg}"
            CornerRadius="8"
            Margin="5,3"
            Padding="2"
            MaxWidth="500"
            HorizontalAlignment="Left">
        <StackPanel>
            <Expander>
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="icon" Text="☰" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Chat.Summary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="Gray"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsInProgress}"
                                     Width="60"
                                     Height="3"
                                     VerticalAlignment="Center"
                                     Margin="6,0,0,0"/>
                    </StackPanel>
                </Expander.Header>
                <TextBlock Text="{Binding SummaryContent}"
                           IsVisible="{Binding !IsInProgress}"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="#444444"
                           Margin="4"/>
            </Expander>
            <views:SiblingNavigationView
                NavigateToPreviousSiblingCommand="{Binding $parent[views:SummarizationMessageView].NavigateToPreviousSiblingCommand}"
                NavigateToNextSiblingCommand="{Binding $parent[views:SummarizationMessageView].NavigateToNextSiblingCommand}"/>
        </StackPanel>
    </Border>

</UserControl>
