<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:DesktopAssistant.UI.Models"
             xmlns:views="using:DesktopAssistant.UI.Views"
             xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             mc:Ignorable="d"
             x:Class="DesktopAssistant.UI.Views.AssistantMessageView"
             x:DataType="models:AssistantChatMessageModel">

    <Border Margin="5"
            Padding="12"
            HorizontalAlignment="Stretch"
            IsVisible="{Binding IsVisible}">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource Chat.ContextMenu.Summarize}"
                          Command="{Binding $parent[views:AssistantMessageView].SummarizeCommand}"
                          CommandParameter="{Binding}"/>
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel>
            <md:MarkdownRenderer MarkdownBuilder="{Binding MarkdownBuilder}"/>
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsStreaming}"
                         Height="3"
                         Margin="0,5,0,0"/>
        </StackPanel>
    </Border>

</UserControl>
