<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAssistant.UI.ViewModels"
             xmlns:dto="using:DesktopAssistant.Application.Dtos"
             xmlns:views="using:DesktopAssistant.UI.Views"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="500"
             x:Class="DesktopAssistant.UI.Views.ProfilesSettingsView"
             x:DataType="vm:ProfilesSettingsViewModel">

    <StackPanel Spacing="12">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="{DynamicResource Profiles.Title}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="{DynamicResource Profiles.Create}"
                    Command="{Binding StartCreateCommand}"
                    Padding="14,7"/>
        </Grid>

        <!-- Error -->
        <Border Background="#FFE0E0"
                Padding="10"
                CornerRadius="4"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#CC0000"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Loading -->
        <ProgressBar IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="3"/>

        <!-- Empty state -->
        <TextBlock Text="{DynamicResource Profiles.Empty}"
                   Foreground="#888"
                   FontSize="13"
                   IsVisible="{Binding !Profiles.Count}"/>

        <!-- Profiles list -->
        <ItemsControl ItemsSource="{Binding Profiles}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="dto:AssistantProfileDto">
                    <Border Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,10"
                            Margin="0,0,0,8">
                        <Grid>

                            <!-- Profile info -->
                            <StackPanel Spacing="3">
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding ModelId}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <!-- "Default" badge -->
                                    <Border Background="#007ACC"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            IsVisible="{Binding IsDefault}">
                                        <TextBlock Text="{DynamicResource Profiles.Badge.Default}"
                                                   Foreground="White"
                                                   FontSize="10"/>
                                    </Border>
                                    <!-- "Summarization" badge -->
                                    <Border Background="#F3E5F5"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            IsVisible="{Binding IsSummarizationProfile}">
                                        <TextBlock Text="{DynamicResource Profiles.Badge.Summarization}"
                                                   Foreground="#6A1B9A"
                                                   FontSize="10"/>
                                    </Border>
                                    <!-- "API key set" badge -->
                                    <Border Background="#E8F5E9"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            IsVisible="{Binding HasApiKey}">
                                        <TextBlock Text="{DynamicResource Profiles.Badge.ApiKey}"
                                                   Foreground="#2E7D32"
                                                   FontSize="10"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="12"
                                           Foreground="#555"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
								<Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
										       Text="{Binding BaseUrl}"
                                               FontSize="11"
                                               Foreground="#999"/>

									<!-- Action buttons — WrapPanel: wraps to a new line when there is not enough width -->
									<WrapPanel Orientation="Horizontal"
											   VerticalAlignment="Bottom"
											   HorizontalAlignment="Right">
										<Button Content="{DynamicResource Profiles.Action.SetDefault}"
												Command="{Binding $parent[ItemsControl].((vm:ProfilesSettingsViewModel)DataContext).SetDefaultCommand}"
												CommandParameter="{Binding}"
												FontSize="11"
												Padding="10,5"
												Margin="0,0,6,4"
												IsVisible="{Binding !IsDefault}"/>
										<Button Content="{DynamicResource Profiles.Action.SetSummarization}"
												Command="{Binding $parent[ItemsControl].((vm:ProfilesSettingsViewModel)DataContext).SetSummarizationCommand}"
												CommandParameter="{Binding}"
												FontSize="11"
												Padding="10,5"
												Margin="0,0,6,4"
												IsVisible="{Binding !IsSummarizationProfile}"/>
										<Button Content="{DynamicResource Profiles.Action.Edit}"
												Command="{Binding $parent[ItemsControl].((vm:ProfilesSettingsViewModel)DataContext).StartEditCommand}"
												CommandParameter="{Binding}"
												FontSize="11"
												Padding="10,5"
												Margin="0,0,6,4"/>
										<Button Content="{DynamicResource Profiles.Action.Delete}"
												Command="{Binding $parent[ItemsControl].((vm:ProfilesSettingsViewModel)DataContext).DeleteProfileCommand}"
												CommandParameter="{Binding}"
												FontSize="11"
												Padding="10,5"
												Margin="0,0,0,4"
												Background="#FFEBEE"
												Foreground="#C62828"/>
									</WrapPanel>
								</Grid>
                            </StackPanel>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Inline profile editor -->
        <Panel IsVisible="{Binding IsEditorVisible}">
            <views:ProfileEditorView DataContext="{Binding ActiveEditor}"/>
        </Panel>

    </StackPanel>
</UserControl>
