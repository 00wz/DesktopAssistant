<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        winBtn — window chrome buttons (minimize / maximize / close).
        Used in MainWindow title bar.
    -->
    <Style Selector="Button.winBtn">
        <Setter Property="Width"           Value="46"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Foreground"      Value="{DynamicResource WinBtnFg}"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        Width="{TemplateBinding Width}">
                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Content="{TemplateBinding Content}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.winBtn:pointerover">
        <Setter Property="Background" Value="{DynamicResource WinBtnHoverBg}"/>
    </Style>
    <Style Selector="Button.winBtn:pressed">
        <Setter Property="Background" Value="{DynamicResource WinBtnPressedBg}"/>
    </Style>
    <Style Selector="Button.winBtn.close:pointerover">
        <Setter Property="Background" Value="{DynamicResource WinCloseBtnHoverBg}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.winBtn.close:pressed">
        <Setter Property="Background" Value="{DynamicResource WinCloseBtnPressedBg}"/>
    </Style>

    <!--
        sideBtn — full-width buttons in the sidebar (New Chat, Settings).
        Dark background with left-aligned content and hover/press states.
    -->
    <Style Selector="Button.sideBtn">
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"                    Value="15,11"/>
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="CornerRadius"               Value="0"/>
        <Setter Property="Foreground"                 Value="{DynamicResource SidebarFg}"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.sideBtn:pointerover">
        <Setter Property="Background" Value="{DynamicResource SidebarButtonHoverBg}"/>
    </Style>
    <Style Selector="Button.sideBtn:pressed">
        <Setter Property="Background" Value="{DynamicResource SidebarButtonPressedBg}"/>
    </Style>

    <!--
        convItem — conversation list item button.
        Strips all FluentTheme chrome; visual feedback is handled by layered Borders
        inside the content (active, selected, hover overlays).
    -->
    <Style Selector="Button.convItem">
        <Setter Property="Padding"                    Value="0"/>
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="CornerRadius"               Value="0"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate>
                <!--
                    Border (not ContentPresenter) as the template root: Border with
                    Background="Transparent" reliably accepts hit-tests across its entire
                    bounds, including the margin areas where no child element exists.
                -->
                <Border Background="Transparent">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!--
        convExpander — expand/collapse toggle inside the flat conversation list.
        Strips all Fluent chrome; the row-level Grid background handles hover feedback.
    -->
    <Style Selector="Button.convExpander">
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!--
        nav-btn — navigation buttons inside message bubbles (sibling prev/next arrows).
        Transparent background; dim hover overlay via ContentPresenter background.
    -->
    <Style Selector="Button.nav-btn">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.nav-btn /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#20000000"/>
    </Style>
    <Style Selector="Button.nav-btn:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</Styles>
